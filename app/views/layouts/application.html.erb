<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tutorial App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tutorial App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="container mx-auto px-5 py-4 flex justify-between items-center border-b border-gray-100 mb-8">
      <div class="flex items-center gap-6">
        <%= link_to "Tutorial App", root_path, class: "font-black text-2xl tracking-tight text-blue-600 hover:text-blue-800 transition" %>
        <%= link_to "記事一覧", posts_path, class: "px-4 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-600 font-medium transition duration-200" %>
      </div>

      <nav class="flex items-center gap-2 text-sm font-medium">
        <% if authenticated? %>
          <div class="flex items-center bg-gray-50 px-3 py-1.5 rounded-full border border-gray-100 mr-2">
            <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse mr-2"></div>
            <span class="text-gray-600"><%= Current.user.email_address %></span>
          </div>
          <%= link_to "マイページ", profile_path, class: "px-4 py-2 rounded-lg text-gray-600 hover:bg-gray-100 transition duration-200" %>
          <%= button_to "ログアウト", session_path, method: :delete, class: "px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 hover:bg-red-50 hover:text-red-600 hover:border-red-100 transition duration-200 cursor-pointer" %>
        <% else %>
          <%= link_to "ログイン", new_session_path, class: "px-4 py-2 rounded-lg text-gray-600 hover:bg-gray-100 transition duration-200" %>
          <%= link_to "新規登録", signup_path, class: "px-5 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 shadow-sm transition duration-200" %>
        <% end %>
      </nav>
    </header>

    <main class="container mx-auto px-5 flex flex-col">
      <% if notice %>
        <p class="py-2 px-3 bg-green-50 text-green-700 font-medium rounded-lg inline-block mb-4" id="notice"><%= notice %></p>
      <% end %>

      <% if alert %>
        <p class="py-2 px-3 bg-red-50 text-red-700 font-medium rounded-lg inline-block mb-4" id="alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
