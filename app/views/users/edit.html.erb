<div class="mx-auto md:w-2/3 w-full px-8 pt-8 pb-8">
  <h1 class="font-bold text-4xl mb-6">プロフィール編集</h1>

  <%= form_with(model: @user, url: profile_path, method: :patch, class: "contents") do |form| %>
    <% if @user.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3 mb-6">
        <h2><%= @user.errors.count %> 件のエラーが発生しました:</h2>
        <ul>
          <% @user.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5 bg-gray-100 p-4 rounded-md">
      <label class="block font-semibold mb-1 text-gray-500">メールアドレス (変更不可)</label>
      <p class="text-gray-600"><%= @user.email_address %></p>
    </div>

    <div class="my-5">
      <%= form.label :name, "氏名", class: "block font-semibold mb-1" %>
      <%= form.text_field :name, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :birthdate, "生年月日", class: "block font-semibold mb-1" %>
      <%= form.date_field :birthdate, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :phone_number, "電話番号", class: "block font-semibold mb-1" %>
      <%= form.telephone_field :phone_number, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :address, "住所", class: "block font-semibold mb-1" %>
      <%= form.text_field :address, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="flex gap-4 mt-8">
      <%= form.submit "保存する", class: "rounded-lg py-3 px-8 bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 transition duration-200" %>
      <%= link_to "キャンセル", profile_path, class: "rounded-lg py-3 px-8 bg-gray-100 text-gray-700 font-medium hover:bg-gray-200" %>
    </div>
    <% end %>

    <hr class="my-10 border-gray-100">

    <div class="bg-red-50 p-6 rounded-lg border border-red-100">
    <h3 class="text-lg font-bold text-red-700 mb-2">退会手続き</h3>
    <p class="text-sm text-red-600 mb-4">アカウントを削除すると、これまでの投稿データもすべて削除され、元に戻すことはできません。</p>
    <%= button_to "アカウントを削除する", profile_path, method: :delete, form: { data: { turbo_confirm: "本当に退会しますか？この操作は取り消せません。" } }, class: "rounded-lg py-2 px-4 bg-red-600 text-white font-medium hover:bg-red-700 transition" %>
    </div>
    </div>
