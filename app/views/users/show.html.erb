<div class="mx-auto md:w-2/3 w-full px-8 pt-8 pb-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">マイページ</h1>
    <%= link_to "プロフィールを編集", edit_profile_path, class: "rounded-lg py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium" %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-100">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-100">
      <h3 class="text-lg leading-6 font-medium text-gray-900">登録情報</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">個人のプロフィール詳細</p>
    </div>
    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">氏名</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @user.name.presence || "未登録" %></dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">メールアドレス</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @user.email_address %></dd>
        </div>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">生年月日</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @user.birthdate.presence || "未登録" %></dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">電話番号</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @user.phone_number.presence || "未登録" %></dd>
        </div>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">住所</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @user.address.presence || "未登録" %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="mt-6">
    <%= link_to "← 戻る", :back, class: "text-blue-600 hover:underline" %>
  </div>
</div>
