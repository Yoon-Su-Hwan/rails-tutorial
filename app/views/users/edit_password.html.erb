<div class="mx-auto md:w-2/3 w-full px-8 pt-8 pb-8">
  <div class="mb-6">
    <%= link_to "← マイページに戻る", profile_path, class: "text-blue-600 hover:underline" %>
  </div>

  <h1 class="font-bold text-4xl mb-6">パスワード変更</h1>

  <%= form_with(model: @user, url: password_profile_path, method: :patch, class: "contents") do |form| %>
    <% if @user.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3 mb-6">
        <h2><%= @user.errors.count %> 件のエラーが発生しました:</h2>
        <ul>
          <% @user.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <p class="text-sm text-gray-500 mb-6">
      セキュリティのため、現在のパスワードと新しいパスワードを入力してください。
    </p>

    <div class="my-5">
      <%= form.label :current_password, "現在のパスワード", class: "block font-semibold mb-1" %>
      <%= form.password_field :current_password, required: true, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full", placeholder: "本人確認のため入力してください" %>
    </div>

    <div class="my-5">
      <%= form.label :password, "新しいパスワード", class: "block font-semibold mb-1" %>
      <%= form.password_field :password, required: true, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full", placeholder: "6文字以上" %>
    </div>

    <div class="my-5">
      <%= form.label :password_confirmation, "新しいパスワード（確認）", class: "block font-semibold mb-1" %>
      <%= form.password_field :password_confirmation, required: true, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full", placeholder: "もう一度入力してください" %>
    </div>

    <div class="flex gap-4 mt-8">
      <%= form.submit "パスワードを更新する", class: "rounded-lg py-3 px-8 bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 transition duration-200" %>
      <%= link_to "キャンセル", profile_path, class: "rounded-lg py-3 px-8 bg-gray-100 text-gray-700 font-medium hover:bg-gray-200" %>
    </div>
  <% end %>
</div>
