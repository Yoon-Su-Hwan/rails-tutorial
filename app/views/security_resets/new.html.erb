<div class="mx-auto md:w-2/3 w-full px-8 pt-8 pb-8 mb-4">
  <h1 class="font-bold text-4xl mb-6 text-center">パスワードの再設定</h1>
  
  <p class="text-gray-600 mb-6 text-center text-sm">
    ご登録済みのメールアドレスを入力してください。<br>設定済みの秘密の質問を表示します。
  </p>

  <%= form_with url: security_resets_path, method: :post, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :email_address, "メールアドレス", class: "block font-semibold mb-1" %>
      <%= form.email_field :email_address, required: true, autofocus: true, placeholder: "example@email.com", class: "block shadow rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="inline">
      <%= form.submit "質問を表示する", class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium cursor-pointer w-full hover:bg-blue-700 transition duration-200" %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to "ログインはこちら", new_session_path, class: "text-blue-600 hover:underline" %>
    </div>
  <% end %>
</div>
