<div class="mx-auto md:w-2/3 w-full px-8 pt-8 pb-8 mb-4">
  <h1 class="font-bold text-4xl mb-6 text-center">新規登録</h1>

  <p class="text-sm text-gray-500 mb-6 text-right">
    <span class="text-red-500">*</span> は必須項目です
  </p>

  <%= form_with(model: @user, url: signup_path, class: "contents") do |form| %>
    <% if @user.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3 mb-6">
        <h2><%= @user.errors.count %> 件のエラーが発生しました:</h2>
        <ul>
          <% @user.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5">
      <%= form.label :name, class: "block font-semibold mb-1" do %>
        氏名 <span class="text-red-500">*</span>
      <% end %>
      <%= form.text_field :name, required: true, placeholder: "山田 太郎", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :birthdate, class: "block font-semibold mb-1" do %>
        生年月日 <span class="text-red-500">*</span>
      <% end %>
      <%= form.date_field :birthdate, required: true, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :phone_number, class: "block font-semibold mb-1" do %>
        電話番号 <span class="text-red-500">*</span>
      <% end %>
      <%= form.telephone_field :phone_number, required: true, placeholder: "090-0000-0000", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :address, class: "block font-semibold mb-1" do %>
        住所 <span class="text-red-500">*</span>
      <% end %>
      <%= form.text_field :address, required: true, placeholder: "東京都渋谷区...", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5 border-t border-gray-100 pt-5">
      <h3 class="text-lg font-bold mb-4">セキュリティ設定</h3>
      <p class="text-sm text-gray-500 mb-4">パスワードを忘れた際の本人確認に使用します。</p>

      <div class="my-5">
        <%= form.label :security_question_id, class: "block font-semibold mb-1" do %>
          秘密の質問 <span class="text-red-500">*</span>
        <% end %>
        <%= form.select :security_question_id, 
                        User::SECURITY_QUESTIONS.each_with_index.map { |q, i| [q, i] }, 
                        { include_blank: "質問を選択してください" }, 
                        { class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full", required: true } %>
      </div>

      <div class="my-5">
        <%= form.label :security_answer, class: "block font-semibold mb-1" do %>
          質問の答え <span class="text-red-500">*</span>
        <% end %>
        <%= form.text_field :security_answer, required: true, placeholder: "答えを入力してください", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
      </div>
    </div>

    <div class="my-5 border-t border-gray-100 pt-5">
      <%= form.label :email_address, class: "block font-semibold mb-1" do %>
        メールアドレス <span class="text-red-500">*</span>
      <% end %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "example@email.com", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :password, class: "block font-semibold mb-1" do %>
        パスワード <span class="text-red-500">*</span>
      <% end %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "6文字以上", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :password_confirmation, class: "block font-semibold mb-1" do %>
        パスワード(確認) <span class="text-red-500">*</span>
      <% end %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "同じパスワードを 再入力してください", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="mt-8 inline-block w-full">
      <%= form.submit "登録する", class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium cursor-pointer w-full hover:bg-blue-700 transition duration-200 shadow-md" %>
    </div>
  <% end %>

  <div class="mt-8 text-center border-t border-gray-100 pt-6">
    <%= link_to "ログインはこちら", new_session_path, class: "text-blue-600 hover:underline font-medium" %>
  </div>
</div>
