<div>
  <h1 class="font-bold text-4xl">Posts#index</h1>
  <p class="mb-4">Find me in app/views/posts/index.html.erb</p>

  <div class="mb-4">
    <%= link_to "New Post", new_post_path, class: "bg-blue-600 hover:bg-blue-800 text-white font-bold py-2 px-6 rounded shadow-md transition duration-200" %>
  </div>

  <%# Loop through all the @posts and show you the title and give you a
  link to them in a table %>
  <table class="table-auto w-full">
    <thead>
      <tr>
        <th class="px-4 py-2">ID</th>
        <th class="px-4 py-2">Title</th>
        <th class="px-4 py-2">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @posts.each do |post| %>
        <tr>
          <td class="border px-4 py-2"><%= post.id %></td>
          <td class="border px-4 py-2"><%= post.title %></td>
          <td class="border px-4 py-2">
            <div class="flex gap-2">
              <%= link_to "Show", post_path(post), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
              <%= link_to "Edit", edit_post_path(post), class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded" %>
              <%= button_to "Delete", post_path(post), method: :delete, form: { data: { turbo_confirm: "削除してよろしいですか?" } }, class: "bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
